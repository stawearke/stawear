                to_name: currentCustomOrder.name,
                customerName: currentCustomOrder.name,
                orderId: "CUST" + Date.now(),
                orderDate: new Date().toLocaleString(),
                orderItems: `Custom ${currentCustomOrder.itemType} x${currentCustomOrder.quantity} (${currentCustomOrder.brandingType})`,
                orderTotal: estimatedPrice,
                deliveryAddress: "Custom order - to be confirmed",
                trackingUrl: window.location.origin + "/track.html?order=" + Date.now(),
                customDetails: currentCustomOrder.description,
                dojangName: currentCustomOrder.dojang,
                from_name: "Stawear Kenya"
            }).then(function() {
                showNotification("✅ Request sent! Check your email for confirmation");
            }).catch(function(error) {
                console.log("Email error:", error);
            });

            showNotification("✅ Custom request sent and saved!");
            closeCustomizeModal();
        }

        // ===== CHECKOUT FUNCTIONS =====
        function openCheckout() {
            if (cart.items.length === 0) {
                showNotification('Your cart is empty');
                return;
            }
            document.getElementById('cartSidebar').classList.remove('active');
            document.getElementById('checkoutModal').classList.add('active');
            updateDeliveryCost();
        }

        function closeCheckout() {
            document.getElementById('checkoutModal').classList.remove('active');
        }

        function selectPaymentMethod(method, element) {
            document.querySelectorAll('.payment-method').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            document.getElementById('paymentMethod').value = method;
        }

        function updateDeliveryCost() {
            const county = document.getElementById('deliveryCounty');
            const cost = parseInt(county.value) || 0;
            document.getElementById('displayDeliveryCost').value = `Ksh ${cost}`;
            document.getElementById('mpesaAmount').textContent = cart.total + cost;
        }

        function processOrder(event) {
            event.preventDefault();
            
            const mpesaCode = document.getElementById('mpesaCode').value;
            if (!mpesaCode) {
                alert("Please enter your M-Pesa confirmation code");
                return;
            }
            
            const order = {
                id: 'STA' + Date.now(),
                customerName: document.getElementById('customerName').value,
                customerPhone: document.getElementById('customerPhone').value,
                customerEmail: document.getElementById('customerEmail').value,
                county: document.getElementById('deliveryCounty').selectedOptions[0]?.text || 'Nairobi',
                deliveryCost: parseInt(document.getElementById('deliveryCounty').value || 0),
                address: document.getElementById('deliveryAddress').value,
                paymentMethod: document.getElementById('paymentMethod').value,
                mpesaCode: mpesaCode,
                items: cart.items,
                subtotal: cart.total,
                total: cart.total + parseInt(document.getElementById('deliveryCounty').value || 0),
                date: new Date().toISOString(),
                status: 'pending'
            };

            const orderItemsList = order.items.map(item => 
                `• ${item.quantity}x ${item.name} (${item.size}) - Ksh ${item.price * item.quantity}`
            ).join('\n');

            // Send WhatsApp to business
            const whatsappMessage = `🔔 *NEW ORDER!* 🔔

*Order #:* ${order.id}
*Customer:* ${order.customerName}
*Phone:* ${order.customerPhone}
*Email:* ${order.customerEmail}
*Total:* Ksh ${order.total}
*M-Pesa Code:* ${order.mpesaCode}

*ITEMS:*
${orderItemsList}

*DELIVERY:*
${order.address}
${order.county} - Ksh ${order.deliveryCost}`;
            
            window.open(`https://wa.me/254727394165?text=${encodeURIComponent(whatsappMessage)}`, '_blank');

            // Send email confirmation
            emailjs.send(window.EMAILJS_SERVICE_ID, window.ORDER_TEMPLATE, {
                to_email: order.customerEmail,
                to_name: order.customerName,
                customerName: order.customerName,
                orderId: order.id,
                orderDate: order.date,
                orderItems: orderItemsList.replace(/\n/g, '<br>'),
                orderTotal: order.total,
                deliveryAddress: `${order.address}, ${order.county}`,
                trackingUrl: window.location.origin + "/track.html?order=" + order.id,
                from_name: "Stawear Kenya"
            }).then(function() {
                showNotification("✅ Order confirmation email sent!");
            });

            // Save order
            const orders = JSON.parse(localStorage.getItem('stawearOrders') || '[]');
            orders.push(order);
            localStorage.setItem('stawearOrders', JSON.stringify(orders));
            
            cart.clearCart();
            closeCheckout();
            showNotification('✅ Order placed! Check your email for confirmation');
        }

        // ===== TRACK ORDER FUNCTIONS =====
        function showTrackOrder() {
            document.getElementById('trackModal').classList.add('active');
        }

        function closeTrackModal() {
            document.getElementById('trackModal').classList.remove('active');
            document.getElementById('trackResult').style.display = 'none';
        }

        function trackOrder() {
            const orderId = document.getElementById('trackOrderId').value;
            if (!orderId) {
                alert('Please enter an order ID');
                return;
            }
            
            const orders = JSON.parse(localStorage.getItem('stawearOrders') || '[]');
            const order = orders.find(o => o.id === orderId);
            
            if (order) {
                const statusSteps = ['pending', 'processing', 'shipped', 'delivered'];
                const currentStep = statusSteps.indexOf(order.status);
                
                let statusHtml = '<div style="display: flex; justify-content: space-between; margin: 20px 0;">';
                statusSteps.forEach((step, index) => {
                    statusHtml += `
                        <div style="text-align: center; flex:1;">
                            <div style="width: 30px; height: 30px; border-radius: 50%; background: ${index <= currentStep ? '#C62828' : '#ddd'}; margin: 0 auto; display: flex; align-items: center; justify-content: center; color: white;">
                                ${index <= currentStep ? '✓' : (index + 1)}
                            </div>
                            <div style="font-size: 0.8rem; margin-top: 5px;">${step.charAt(0).toUpperCase() + step.slice(1)}</div>
                        </div>
                    `;
                });
                statusHtml += '</div>';
                
                document.getElementById('trackStatus').innerHTML = statusHtml;
                document.getElementById('trackDetails').innerHTML = `
                    <p><strong>Order Date:</strong> ${new Date(order.date).toLocaleString()}</p>
                    <p><strong>Total:</strong> Ksh ${order.total}</p>
                    <p><strong>Items:</strong> ${order.items.length}</p>
                    <p><strong>Delivery:</strong> ${order.address}, ${order.county}</p>
                `;
                document.getElementById('trackResult').style.display = 'block';
            } else {
                alert('Order not found');
            }
        }

        // ===== NOTIFICATION =====
        function showNotification(message) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `<i class="fas fa-check-circle"></i><div>${message}</div>`;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // ===== SCROLL FUNCTION =====
        function scrollToSection(sectionId) {
            document.getElementById(sectionId)?.scrollIntoView({ behavior: 'smooth' });
        }
    </script>
</body>
</html>
